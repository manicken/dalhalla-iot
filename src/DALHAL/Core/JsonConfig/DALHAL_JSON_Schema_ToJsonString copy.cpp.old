#include "DALHAL_JSON_Schema_ToJsonString.h"
#include "DALHAL_JSON_Schema_BaseTypes.h"
#include "DALHAL_JSON_Schema_Types.h"

namespace DALHAL {
    
    namespace JsonSchema {
        static void appendQuoted(std::string& out, const char* str) {
            out += '"';
            if (str) out += str;
            out += '"';
        }

        static void appendKey(std::string& out, const char* key) {
            appendQuoted(out, key);
            out += ':';
        }

        static void appendBool(std::string& out, bool v) {
            out += (v ? "true" : "false");
        }

        void generateField(const FieldBase* field, std::string& out)
        {
            if (!field) return;

            out += "{";

            // name
            appendKey(out, "name");
            appendQuoted(out, field->name);
            out += ",";

            // type
            appendKey(out, "type");
            appendQuoted(out, FieldTypeToString(field->type));
            out += ",";

            // required
            appendKey(out, "required");
            appendBool(out, field->policy == FieldPolicy::Required);

            // ---- TYPE SPECIFIC ----

            switch (field->type)
            {
                case FieldType::Int: {
                    auto f = static_cast<const FieldInt*>(field);
                    out += ",";
                    appendKey(out, "min");
                    out += std::to_string(f->minValue);
                    out += ",";
                    appendKey(out, "max");
                    out += std::to_string(f->maxValue);
                    break;
                }

                case FieldType::UInt: {
                    auto f = static_cast<const FieldUInt*>(field);
                    out += ",";
                    appendKey(out, "min");
                    out += std::to_string(f->minValue);
                    out += ",";
                    appendKey(out, "max");
                    out += std::to_string(f->maxValue);
                    break;
                }

                case FieldType::Float: {
                    auto f = static_cast<const FieldFloat*>(field);
                    out += ",";
                    appendKey(out, "min");
                    if (isnanf(f->minValue)) {
                        out += "null";
                    } else {
                        out += std::to_string(f->minValue);
                    }
                    out += ",";
                    appendKey(out, "max");
                    if (isnanf(f->maxValue)) {
                        out += "null";
                    } else {
                        out += std::to_string(f->maxValue);
                    }
                    break;
                }

                case FieldType::String:
                case FieldType::UID:
                case FieldType::UID_Path:
                case FieldType::StringConstraint: {
                    auto f = static_cast<const FieldString*>(field);

                    if (f->minLength > 0) {
                        out += ",";
                        appendKey(out, "minLength");
                        out += std::to_string(f->minLength);
                    }

                    if (f->maxLength > 0) {
                        out += ",";
                        appendKey(out, "maxLength");
                        out += std::to_string(f->maxLength);
                    }

                    if (f->allowedValues) {
                        out += ",";
                        appendKey(out, "allowedValues");
                        out += "[";

                        for (int i = 0; f->allowedValues[i] != nullptr; ++i) {
                            if (i > 0) out += ",";
                            appendQuoted(out, f->allowedValues[i]);
                        }

                        out += "]";
                    }

                    break;
                }

                case FieldType::Object: {
                    auto f = static_cast<const FieldObject*>(field);

                    out += ",";
                    appendKey(out, "fields");
                    out += "[";

                    if (f->subtype && f->subtype->fields) {
                        for (int i = 0; f->subtype->fields[i] != nullptr; ++i) {
                            if (i > 0) out += ",";
                            generateField(f->subtype->fields[i], out);
                        }
                    }

                    out += "]";
                    break;
                }

                case FieldType::Array: {
                    auto f = static_cast<const FieldArray*>(field);

                    out += ",";
                    appendKey(out, "items");

                    if (f->subtype) {
                        out += "{";
                        appendKey(out, "type");
                        appendQuoted(out, "Object");
                        out += ",";
                        appendKey(out, "fields");
                        out += "[";

                        if (f->subtype->fields) {
                            for (int i = 0; f->subtype->fields[i] != nullptr; ++i) {
                                if (i > 0) out += ",";
                                generateField(f->subtype->fields[i], out);
                            }
                        }

                        out += "]}";
                    } else {
                        out += "null";
                    }

                    break;
                }

                case FieldType::ArrayPrimitive: {
                    auto f = static_cast<const FieldArrayPrimitive*>(field);

                    out += ",";
                    appendKey(out, "primitiveFlags");
                    out += std::to_string(f->primitiveTypeFlags);
                    break;
                }

                case FieldType::OneOfGroup:
                case FieldType::AllOfGroup:
                case FieldType::FieldsGroup: {

                    const FieldBase* const* groupFields = nullptr;

                    if (field->type == FieldType::OneOfGroup) {
                        groupFields = static_cast<const OneOfGroup*>(field)->fields;
                    } else if (field->type == FieldType::AllOfGroup) {
                        groupFields = static_cast<const AllOfGroup*>(field)->fields;
                    } else {
                        groupFields = static_cast<const FieldsGroup*>(field)->fields;
                    }

                    out += ",";
                    appendKey(out, "groupType");
                    appendQuoted(out, FieldTypeToString(field->type));

                    out += ",";
                    appendKey(out, "fields");
                    out += "[";

                    for (int i = 0; groupFields && groupFields[i] != nullptr; ++i) {
                        if (i > 0) out += ",";
                        generateField(groupFields[i], out);
                    }

                    out += "]";
                    break;
                }

                default:
                    break;
            }

            out += "}";
        }

        void generateSchema(const JsonObjectSchema* schema, std::string& out)
        {
            if (!schema) return;

            out += "{";

            appendKey(out, "type");
            appendQuoted(out, "Object");

            out += ",";
            appendKey(out, "name");
            appendQuoted(out, schema->typeName);

            out += ",";
            appendKey(out, "unknownPolicy");
            appendQuoted(out, UnknownFieldPolicyToString(schema->unknownFieldPolicy));

            out += ",";
            appendKey(out, "fields");
            out += "[";

            if (schema->fields) {
                for (int i = 0; schema->fields[i] != nullptr; ++i) {
                    if (i > 0) out += ",";
                    generateField(schema->fields[i], out);
                }
            }

            out += "]";

            out += "}";
        }
    }

}